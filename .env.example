# Server
# MUST be at least 32 chars. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# The app refuses to start if this is missing or too short.
SESSION_SECRET=replace_with_32_plus_random_chars_use_openssl_rand
PORT=8000

# Database
DATABASE_URL=sqlite:///./data/leads.db
# Wipe all leads/jobs/activity (NOT user accounts) on every app start, so each
# session begins clean. Set to false to keep data once you're ready to persist.
RESET_DATA_ON_START=true

# Claude
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5

# Scraper — REQUIRED for Find Leads. Install gosom and point GOSOM_BIN at the
# binary (see README "Adding gosom"). There is no demo/fake fallback: if gosom
# isn't found, a scrape job fails with a clear "install gosom" error.
GOSOM_BIN=/usr/local/bin/google-maps-scraper
SCRAPE_OUTPUT_DIR=./data/scrapes
SCRAPE_TIMEOUT_SECONDS=600
# How long gosom waits with no new results before finishing a search. Lower =
# searches finish faster (the job stays "running" at least this long). e.g. 45s, 1m, 2m
GOSOM_INACTIVITY=45s

# LinkedIn source — a shared internal account is baked into the backend, so the
# team gets real LinkedIn data with no per-user setup. To override with your own
# account, uncomment and set these:
# LINKEDIN_ENABLED=true
# LINKEDIN_USER=
# LINKEDIN_PASS=
# More reliable for new accounts: paste the li_at + JSESSIONID cookies from a
# logged-in LinkedIn browser session (skips password login / challenges).
# LINKEDIN_COOKIE=
# LINKEDIN_JSESSIONID=
# Safety rails: max leads/day per source (0 = unlimited) + polite delay (sec).
LINKEDIN_DAILY_CAP=80
GMAPS_DAILY_CAP=0
LINKEDIN_THROTTLE_SECONDS=2.0

# Frontend (for CORS)
FRONTEND_ORIGIN=http://localhost:5173
